{
  "name": "LabOps \u2014 VM Management API",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "GET",
        "path": "vms",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-list-vms",
      "name": "Webhook: List VMs",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        260,
        200
      ],
      "webhookId": "labops-list-vms"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.PROXMOX_URL }}/api2/json/nodes/{{ $env.PROXMOX_NODE }}/qemu",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "PVEAPIToken={{ $env.PROXMOX_TOKEN_ID }}={{ $env.PROXMOX_TOKEN_SECRET }}"
            }
          ]
        },
        "options": {
          "allowUnauthorizedCerts": true
        }
      },
      "id": "http-proxmox-list",
      "name": "GET Proxmox VMs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        480,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse Proxmox API response and format for dashboard\nconst items = $input.all();\nconst response = items[0]?.json;\nconst vmList = response?.data || [];\n\n// Filter to lab VMs (IDs 200-299) and format\nconst vms = vmList\n  .filter(vm => vm.vmid >= 200 && vm.vmid < 300)\n  .map(vm => ({\n    vmid: vm.vmid,\n    name: vm.name || `vm-${vm.vmid}`,\n    status: vm.status,\n    uptime: vm.uptime || 0,\n    cpu: vm.cpu || 0,\n    mem: vm.mem || 0,\n    maxmem: vm.maxmem || 0,\n    tags: vm.tags || '',\n    ip: null // IP requires a separate QEMU agent call\n  }))\n  .sort((a, b) => a.vmid - b.vmid);\n\nreturn [{ json: { vms } }];"
      },
      "id": "code-format-vms",
      "name": "Format VM List",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        200
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}"
      },
      "id": "respond-list-vms",
      "name": "Respond: VM List",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        920,
        200
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "vms/:vmid/start",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-start-vm",
      "name": "Webhook: Start VM",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        260,
        440
      ],
      "webhookId": "labops-start-vm"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.PROXMOX_URL }}/api2/json/nodes/{{ $env.PROXMOX_NODE }}/qemu/{{ $json.params.vmid }}/status/start",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "PVEAPIToken={{ $env.PROXMOX_TOKEN_ID }}={{ $env.PROXMOX_TOKEN_SECRET }}"
            }
          ]
        },
        "options": {
          "allowUnauthorizedCerts": true
        }
      },
      "id": "http-start-vm",
      "name": "POST Start VM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        480,
        440
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, action: 'start', vmid: $('Webhook: Start VM').first().json.params.vmid }) }}"
      },
      "id": "respond-start-vm",
      "name": "Respond: Start VM",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        700,
        440
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "vms/:vmid/stop",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-stop-vm",
      "name": "Webhook: Stop VM",
      "type": "n8n-nodes-base.webhook",
