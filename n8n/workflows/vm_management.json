        "path": "vms/:vmid/destroy",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-destroy-vm",
      "name": "Webhook: Destroy VM",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
