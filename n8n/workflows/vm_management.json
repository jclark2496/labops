        "method": "DELETE",
        "url": "={{ $env.PROXMOX_URL }}/api2/json/nodes/{{ $env.PROXMOX_NODE }}/qemu/{{ $json.params.vmid }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
