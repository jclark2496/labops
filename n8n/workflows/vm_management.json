        },
        "options": {
          "allowUnauthorizedCerts": true
        }
      },
      "id": "http-stop-vm",
      "name": "POST Stop VM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        480,
