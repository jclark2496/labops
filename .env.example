# =============================================================================
# LabOps — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — your secrets will NOT be committed.
# =============================================================================

# ── n8n Workflow Automation ─────────────────────────────────────────────────
# Password for the n8n admin UI (required)
N8N_PASSWORD=SEdemo2026

# ── Proxmox Integration ────────────────────────────────────────────────────
# Your Proxmox server URL
# Example: https://192.168.1.2:8006
PROXMOX_URL=

# Proxmox node name (run 'pvesh get /nodes' on your Proxmox host)
# Example: pm1
PROXMOX_NODE=

# Proxmox API token — create in Datacenter → Permissions → API Tokens
# Required permissions: PVEVMAdmin + PVEDatastoreAdmin + PVESDNUser
# Example: terraform-prov@pve!terraform
PROXMOX_TOKEN_ID=

# Proxmox API token secret — shown once when you create the token
PROXMOX_TOKEN_SECRET=

# ── Windows Template ──────────────────────────────────────────────────────
# Name of Windows 11 ISO uploaded to Proxmox storage (e.g., Win11_23H2_English_x64.iso)
WIN11_ISO=
# Name of VirtIO drivers ISO on Proxmox storage (e.g., virtio-win-0.1.240.iso)
VIRTIO_ISO=virtio-win.iso
# Template VM ID (default: 100)
TEMPLATE_VM_ID=100

# ── Guacamole (Browser-Based RDP) ──────────────────────────────────────────
# Admin credentials for Guacamole — set on first login at /guacamole
# These are used by the dashboard to create RDP connections
GUAC_ADMIN_USER=guacadmin
GUAC_ADMIN_PASSWORD=guacadmin

# ── Lab VM Defaults ─────────────────────────────────────────────────────────
# Default credentials for lab VMs (used by Ansible and dashboard RDP connect)
LAB_VM_USER=demo
LAB_VM_PASSWORD=SEdemo2026

# ── Optional: Port Overrides ───────────────────────────────────────────────
# Change these if the defaults conflict with other services on your host
# NGINX_PORT=8080
# N8N_PORT=5678
# GUAC_PORT=8085
# PORTAINER_PORT=9000

# ── Optional: Network ──────────────────────────────────────────────────────
# Docker bridge subnet — change only if 172.20.0.0/24 conflicts
# LAB_NETWORK_SUBNET=172.20.0.0/24

# ── Optional: Timezone ─────────────────────────────────────────────────────
# TIMEZONE=America/Chicago
